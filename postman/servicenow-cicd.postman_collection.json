{
  "info": {
    "_postman_id": "a1b2c3d4-0001-4c3d-8e9f-000000000001",
    "name": "ServiceNow CI/CD Pipeline",
    "description": "Manual test suite mirroring every API call made by the GitHub Actions CI/CD pipeline.\n\n**Before you start:**\n1. Open the collection Variables tab and fill in all credential variables.\n2. Set `SET_NAME` to the exact name of the update set you want to test.\n3. Set `SN_DEV_UPDATE_SOURCE_ID` to the sys_id of the Remote Update Source record on test.\n4. Run requests top-to-bottom — post-response scripts auto-populate `SYS_ID`, `PROGRESS_ID`, `REMOTE_SYS_ID`, etc. as you go.\n\nThe workflow order mirrors the pipeline: Discover → Precheck → Transfer → Preview → Commit.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "SN_DEV_INSTANCE",
      "value": "",
      "type": "string",
      "description": "Dev instance subdomain only, e.g. dev12345 (not the full URL)"
    },
    {
      "key": "SN_DEV_USER",
      "value": "",
      "type": "string",
      "description": "Dev admin username"
    },
    {
      "key": "SN_DEV_PASS",
      "value": "",
      "type": "string",
      "description": "Dev admin password"
    },
    {
      "key": "SN_TEST_INSTANCE",
      "value": "",
      "type": "string",
      "description": "Test instance subdomain only, e.g. dev67890"
    },
    {
      "key": "SN_TEST_USER",
      "value": "",
      "type": "string",
      "description": "Test admin username"
    },
    {
      "key": "SN_TEST_PASS",
      "value": "",
      "type": "string",
      "description": "Test admin password"
    },
    {
      "key": "SN_DEV_UPDATE_SOURCE_ID",
      "value": "",
      "type": "string",
      "description": "sys_id of the sys_update_set_source record on test. One-time setup: on test go to sys_update_set_source_list.do, create a record pointing at dev, copy its sys_id here."
    },
    {
      "key": "SET_NAME",
      "value": "Demo Announcement",
      "type": "string",
      "description": "Exact update set name. Auto-populated from the first result of '1 · Discover > [Dev] List complete update sets'."
    },
    {
      "key": "SYS_ID",
      "value": "",
      "type": "string",
      "description": "sys_id of the local update set on dev. Auto-populated from '1 · Discover > [Dev] List complete update sets'."
    },
    {
      "key": "PROGRESS_ID",
      "value": "",
      "type": "string",
      "description": "sys_id of the CI/CD progress record. Auto-populated from '3 · Transfer > Trigger retrieval' and '5 · Commit > Trigger commit'."
    },
    {
      "key": "REMOTE_SYS_ID",
      "value": "",
      "type": "string",
      "description": "sys_id of the remote update set record on test. Auto-populated from '2 · Precheck' or '3 · Transfer > Verify remote update set'."
    }
  ],
  "item": [
    {
      "name": "1 · Discover",
      "description": "Mirrors discover.py — queries both instances to build the deployment list.\n\nRun all three requests to replicate what the Discover job does. The first request auto-populates SYS_ID and SET_NAME for the oldest complete update set on dev.",
      "item": [
        {
          "name": "[Dev] List complete update sets",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.result && json.result.length > 0) {",
                  "        var first = json.result[0];",
                  "        pm.collectionVariables.set('SYS_ID', first.sys_id);",
                  "        pm.collectionVariables.set('SET_NAME', first.name);",
                  "        console.log('[Auto] SYS_ID  → ' + first.sys_id);",
                  "        console.log('[Auto] SET_NAME → ' + first.name);",
                  "        pm.test('At least one complete update set found', function () {",
                  "            pm.expect(json.result.length).to.be.above(0);",
                  "        });",
                  "    } else {",
                  "        console.warn('No complete update sets found on dev.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_DEV_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_DEV_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_DEV_INSTANCE}}.service-now.com/api/now/table/sys_update_set?sysparm_query=state=complete&sysparm_orderby=sys_created_on&sysparm_fields=sys_id,name,description,state,sys_created_on&sysparm_limit=500",
              "protocol": "https",
              "host": ["{{SN_DEV_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_update_set"],
              "query": [
                { "key": "sysparm_query", "value": "state=complete", "description": "Filter to complete update sets only" },
                { "key": "sysparm_orderby", "value": "sys_created_on", "description": "Oldest first — preserves dependency order" },
                { "key": "sysparm_fields", "value": "sys_id,name,description,state,sys_created_on" },
                { "key": "sysparm_limit", "value": "500" }
              ]
            },
            "description": "Fetches all complete local update sets from dev, oldest-first.\n\n**Script:** `discover.py` (Query 1)\n\n**Post-response:** automatically sets `SYS_ID` and `SET_NAME` collection variables from the first (oldest) result."
          },
          "response": []
        },
        {
          "name": "[Test] List committed remote update sets",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set?sysparm_query=state=committed&sysparm_fields=name,state&sysparm_limit=500",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set"],
              "query": [
                { "key": "sysparm_query", "value": "state=committed" },
                { "key": "sysparm_fields", "value": "name,state" },
                { "key": "sysparm_limit", "value": "500" }
              ]
            },
            "description": "Lists all already-committed remote update sets on test.\n\n**Script:** `discover.py` (Query 2)\n\nUsed to determine which dev sets are already deployed and can be skipped. If any names appear here that do NOT exist in the dev complete list, the pipeline will fail with a 'test is ahead of dev' error."
          },
          "response": []
        },
        {
          "name": "[Test] List loaded and previewed remote update sets",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set?sysparm_query=stateIN(loaded,previewed)&sysparm_fields=sys_id,name,state&sysparm_limit=50",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set"],
              "query": [
                { "key": "sysparm_query", "value": "stateIN(loaded,previewed)", "description": "Partial-state sets — pipeline will resume these from the appropriate step" },
                { "key": "sysparm_fields", "value": "sys_id,name,state" },
                { "key": "sysparm_limit", "value": "50" }
              ]
            },
            "description": "Lists remote update sets on test that are partially deployed (retrieved but not yet committed).\n\n**Script:** `discover.py` (Query 3)\n\nSets in `loaded` state will resume from Preview. Sets in `previewed` state will resume from Commit."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2 · Precheck",
      "description": "Mirrors precheck.py — queries test live for the current state of a specific update set.\n\nRun this before each deploy to confirm whether the set needs a full deploy, a partial resume, or can be skipped entirely. The post-response script sets REMOTE_SYS_ID if a record is found.",
      "item": [
        {
          "name": "[Test] Get remote update set by name",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.result && json.result.length > 0) {",
                  "        var latest = json.result[json.result.length - 1];",
                  "        pm.collectionVariables.set('REMOTE_SYS_ID', latest.sys_id);",
                  "        console.log('[Auto] REMOTE_SYS_ID → ' + latest.sys_id + '  (state: ' + latest.state + ')');",
                  "        var stateMap = {",
                  "            'committed':  'action = skip (already deployed)',",
                  "            'previewed':  'action = resume_previewed (go straight to commit)',",
                  "            'loaded':     'action = resume_loaded (start from preview)',",
                  "        };",
                  "        var action = stateMap[latest.state] || 'action = deploy (full deploy needed)';",
                  "        console.log('[Precheck] ' + action);",
                  "        pm.test('Precheck state is recognised', function () {",
                  "            pm.expect(['committed','previewed','loaded']).to.include(latest.state);",
                  "        });",
                  "    } else {",
                  "        console.log('[Precheck] Set not found on test → action = deploy (full deploy needed)');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set?sysparm_query=name={{SET_NAME}}&sysparm_fields=sys_id,name,state&sysparm_orderby=sys_created_on&sysparm_limit=10",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set"],
              "query": [
                { "key": "sysparm_query", "value": "name={{SET_NAME}}", "description": "Exact name match" },
                { "key": "sysparm_fields", "value": "sys_id,name,state" },
                { "key": "sysparm_orderby", "value": "sys_created_on", "description": "Oldest first; script uses the last element as the most recent" },
                { "key": "sysparm_limit", "value": "10" }
              ]
            },
            "description": "Queries test for the current deployment state of the update set named `{{SET_NAME}}`.\n\n**Script:** `precheck.py`\n\n**Post-response:** sets `REMOTE_SYS_ID` from the most-recently-created matching record, and logs the resulting pipeline action."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3 · Transfer",
      "description": "Mirrors transfer.py — tells the test instance to pull the update set directly from dev using the CI/CD Update Set Retrieve API.\n\nPrerequisite: a Remote Update Source record must exist on test (`sys_update_set_source_list.do`) with dev credentials. Its sys_id goes in the `SN_DEV_UPDATE_SOURCE_ID` collection variable.\n\nRun all three requests in order: trigger retrieval → poll progress until status=2 → verify the remote record was created.",
      "item": [
        {
          "name": "[Test] Trigger retrieval",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    try {",
                  "        var progressId  = json.result.links.progress.id;",
                  "        var progressUrl = json.result.links.progress.url;",
                  "        pm.collectionVariables.set('PROGRESS_ID', progressId);",
                  "        console.log('[Auto] PROGRESS_ID → ' + progressId);",
                  "        console.log('[Transfer] Track progress at: ' + progressUrl);",
                  "        pm.test('Progress ID returned', function () {",
                  "            pm.expect(progressId).to.be.a('string').and.not.empty;",
                  "        });",
                  "    } catch (e) {",
                  "        console.error('[Transfer] Unexpected response shape — check body for error details.');",
                  "        pm.test('Progress link present in response', function () { pm.expect(false).to.be.true; });",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/sn_cicd/update_set/retrieve?update_set_id={{SYS_ID}}&update_source_id={{SN_DEV_UPDATE_SOURCE_ID}}",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "sn_cicd", "update_set", "retrieve"],
              "query": [
                { "key": "update_set_id", "value": "{{SYS_ID}}", "description": "sys_id of the local update set on dev" },
                { "key": "update_source_id", "value": "{{SN_DEV_UPDATE_SOURCE_ID}}", "description": "sys_id of the sys_update_set_source record on test that holds dev credentials" }
              ]
            },
            "description": "Calls the CI/CD Update Set Retrieve API on test. Test reaches out to dev directly using the credentials in the Remote Update Source record and pulls the update set.\n\n**Script:** `transfer.py` (step 1)\n\n**Post-response:** auto-sets `PROGRESS_ID` from `result.links.progress.id`.\n\n**Note:** The request is sent to the TEST instance, not dev. Test does the pulling."
          },
          "response": []
        },
        {
          "name": "[Test] Poll retrieval progress",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    var result = json.result || {};",
                  "    var status      = parseInt(result.status || '0');",
                  "    var pct         = result.percent_complete || 0;",
                  "    var statusLabel = result.status_label || '';",
                  "    console.log('[Poll] ' + pct + '% — ' + statusLabel + '  (status=' + status + ')');",
                  "    var statusMap = { 0: 'Pending', 1: 'Running', 2: 'Successful', 3: 'Failed', 4: 'Cancelled' };",
                  "    pm.test('Progress status: ' + (statusMap[status] || status), function () {",
                  "        pm.expect([0,1,2]).to.include(status);",
                  "    });",
                  "    if (status === 2) {",
                  "        console.log('[Poll] Retrieval complete — proceed to Verify remote update set.');",
                  "    } else if (status >= 3) {",
                  "        var detail = result.status_detail || result.error || result.status_message || '';",
                  "        console.error('[Poll] Retrieval failed: ' + detail);",
                  "    } else {",
                  "        console.log('[Poll] Still running. Re-send this request in a few seconds.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/sn_cicd/progress/{{PROGRESS_ID}}",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "sn_cicd", "progress", "{{PROGRESS_ID}}"]
            },
            "description": "Polls the CI/CD progress record for the retrieval operation. Re-send every few seconds until `status` is `2` (Successful).\n\n**Script:** `transfer.py` (step 2, via `sn.py:poll_progress`)\n\n**Status codes:** 0=Pending, 1=Running, 2=Successful, 3=Failed, 4=Cancelled"
          },
          "response": []
        },
        {
          "name": "[Test] Verify remote update set",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.result && json.result.length > 0) {",
                  "        var record = json.result[0];",
                  "        pm.collectionVariables.set('REMOTE_SYS_ID', record.sys_id);",
                  "        console.log('[Auto] REMOTE_SYS_ID → ' + record.sys_id + '  (state: ' + record.state + ')');",
                  "        pm.test('Remote update set found in loaded state', function () {",
                  "            pm.expect(record.state).to.equal('loaded');",
                  "        });",
                  "    } else {",
                  "        console.error('[Transfer] No remote update set found for SET_NAME=' + pm.collectionVariables.get('SET_NAME'));",
                  "        pm.test('Remote update set found', function () { pm.expect(json.result.length).to.be.above(0); });",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set?sysparm_query=name={{SET_NAME}}&sysparm_fields=sys_id,name,state&sysparm_orderbydesc=sys_created_on&sysparm_limit=1",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set"],
              "query": [
                { "key": "sysparm_query", "value": "name={{SET_NAME}}", "description": "Exact name match" },
                { "key": "sysparm_fields", "value": "sys_id,name,state" },
                { "key": "sysparm_orderbydesc", "value": "sys_created_on", "description": "Most recent first" },
                { "key": "sysparm_limit", "value": "1" }
              ]
            },
            "description": "Confirms the retrieval created a `sys_remote_update_set` record in `loaded` state.\n\n**Script:** `transfer.py` (step 3)\n\n**Post-response:** sets `REMOTE_SYS_ID` — needed by all subsequent Preview and Commit requests."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4 · Preview",
      "description": "Mirrors poll_preview.py — triggers collision-detection preview on test and polls until complete.\n\nIf the set is already in `previewed` state (resume_previewed scenario), skip directly to '5 · Commit'.",
      "item": [
        {
          "name": "[Test] Trigger preview",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/sys_remote_update_set_preview.do?sysparm_sys_id={{REMOTE_SYS_ID}}",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["sys_remote_update_set_preview.do"],
              "query": [
                { "key": "sysparm_sys_id", "value": "{{REMOTE_SYS_ID}}" }
              ]
            },
            "description": "Starts the collision-detection preview for the remote update set. The processor runs asynchronously — this call only kicks it off.\n\n**Script:** `poll_preview.py` (`client.post`)\n\n**Expected response:** HTTP 200. Use 'Poll preview state' to track progress."
          },
          "response": []
        },
        {
          "name": "[Test] Poll preview state",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    var state = json.result && json.result.state;",
                  "    console.log('[Poll] Preview state: ' + state);",
                  "    pm.test('Preview state is valid', function () {",
                  "        pm.expect(['previewed', 'loaded', 'previewing', 'error']).to.include(state);",
                  "    });",
                  "    if (state === 'previewed') {",
                  "        console.log('[Poll] Preview complete — proceed to List preview conflicts.');",
                  "    } else if (state === 'error') {",
                  "        console.error('[Poll] Preview ended in error. Open test → Retrieved Update Sets to investigate.');",
                  "    } else {",
                  "        console.log('[Poll] Still running. Re-send this request in a few seconds.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set/{{REMOTE_SYS_ID}}?sysparm_fields=sys_id,name,state",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set", "{{REMOTE_SYS_ID}}"],
              "query": [
                { "key": "sysparm_fields", "value": "sys_id,name,state" }
              ]
            },
            "description": "Checks the current state of the remote update set. Re-send every 10 seconds until `state` is `previewed`.\n\n**Script:** `poll_preview.py` (poll loop)\n\n**State transitions:** `loaded` → `previewing` → `previewed` (or `error`)"
          },
          "response": []
        },
        {
          "name": "[Test] List preview conflicts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    var conflicts = json.result || [];",
                  "    pm.test('No preview conflicts', function () {",
                  "        pm.expect(conflicts.length).to.equal(0);",
                  "    });",
                  "    if (conflicts.length > 0) {",
                  "        console.error('[Conflicts] ' + conflicts.length + ' conflict(s) found. Resolve before committing:');",
                  "        conflicts.forEach(function(c) {",
                  "            console.error('  - ' + (c.description || '(no description)'));",
                  "        });",
                  "    } else {",
                  "        console.log('[Conflicts] None — safe to commit.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_update_preview_problem?sysparm_query=remote_update_set={{REMOTE_SYS_ID}}^type=conflict&sysparm_fields=sys_id,type,description&sysparm_limit=50",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_update_preview_problem"],
              "query": [
                { "key": "sysparm_query", "value": "remote_update_set={{REMOTE_SYS_ID}}^type=conflict", "description": "Conflict-type problems only for this remote update set" },
                { "key": "sysparm_fields", "value": "sys_id,type,description" },
                { "key": "sysparm_limit", "value": "50" }
              ]
            },
            "description": "Checks for collision-type preview problems after preview completes.\n\n**Script:** `poll_preview.py` (post-poll conflict check)\n\n**Expected result:** Empty `result` array. If any conflicts appear, resolve them manually in test (go to `sys_remote_update_set_list.do`) before re-running."
          },
          "response": []
