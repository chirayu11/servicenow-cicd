    },
    {
      "name": "5 · Commit",
      "description": "Mirrors commit.py — triggers the commit via the CI/CD API and polls until committed.\n\nRun in order: trigger → poll progress → verify state.",
      "item": [
        {
          "name": "[Test] Trigger commit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    try {",
                  "        var progressId  = json.result.links.progress.id;",
                  "        var progressUrl = json.result.links.progress.url;",
                  "        pm.collectionVariables.set('PROGRESS_ID', progressId);",
                  "        console.log('[Auto] PROGRESS_ID → ' + progressId);",
                  "        console.log('[Commit] Track progress at: ' + progressUrl);",
                  "        pm.test('Progress ID returned', function () {",
                  "            pm.expect(progressId).to.be.a('string').and.not.empty;",
                  "        });",
                  "    } catch (e) {",
                  "        console.error('[Commit] Unexpected response shape — check body for error details.');",
                  "        pm.test('Progress link present in response', function () { pm.expect(false).to.be.true; });",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/sn_cicd/update_set/commit/{{REMOTE_SYS_ID}}",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "sn_cicd", "update_set", "commit", "{{REMOTE_SYS_ID}}"]
            },
            "description": "Triggers the commit of the previewed update set via the CI/CD Update Set Commit API. The commit runs asynchronously.\n\n**Script:** `commit.py`\n\n**Post-response:** auto-sets `PROGRESS_ID` from `result.links.progress.id`.\n\n**Note:** This replaces the legacy `sys_remote_update_set_commit.do` endpoint, which requires a CSRF token from a browser session and silently does nothing when called with Basic Auth alone."
          },
          "response": []
        },
        {
          "name": "[Test] Poll commit progress",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    var result = json.result || {};",
                  "    var status      = parseInt(result.status || '0');",
                  "    var pct         = result.percent_complete || 0;",
                  "    var statusLabel = result.status_label || '';",
                  "    console.log('[Poll] ' + pct + '% — ' + statusLabel + '  (status=' + status + ')');",
                  "    var statusMap = { 0: 'Pending', 1: 'Running', 2: 'Successful', 3: 'Failed', 4: 'Cancelled' };",
                  "    pm.test('Progress status: ' + (statusMap[status] || status), function () {",
                  "        pm.expect([0,1,2]).to.include(status);",
                  "    });",
                  "    if (status === 2) {",
                  "        console.log('[Poll] Commit complete — proceed to Verify committed state.');",
                  "    } else if (status >= 3) {",
                  "        var detail = result.status_detail || result.error || result.status_message || '';",
                  "        console.error('[Poll] Commit failed: ' + detail);",
                  "    } else {",
                  "        console.log('[Poll] Still running. Re-send this request in a few seconds.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/sn_cicd/progress/{{PROGRESS_ID}}",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "sn_cicd", "progress", "{{PROGRESS_ID}}"]
            },
            "description": "Polls the CI/CD progress record for the commit operation. Re-send every few seconds until `status` is `2` (Successful).\n\n**Script:** `commit.py` (via `sn.py:poll_progress`)\n\n**Status codes:** 0=Pending, 1=Running, 2=Successful, 3=Failed, 4=Cancelled"
          },
          "response": []
        },
        {
          "name": "[Test] Verify committed state",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    var state = json.result && json.result.state;",
                  "    console.log('[Verify] Remote update set state: ' + state);",
                  "    pm.test('Update set is committed', function () {",
                  "        pm.expect(state).to.equal('committed');",
                  "    });",
                  "    if (state === 'committed') {",
                  "        console.log('[Verify] Successfully committed. Changes are now live on test.');",
                  "    } else {",
                  "        console.warn('[Verify] Unexpected state: ' + state + '. Check test → Retrieved Update Sets.');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{SN_TEST_USER}}", "type": "string" },
                { "key": "password", "value": "{{SN_TEST_PASS}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "https://{{SN_TEST_INSTANCE}}.service-now.com/api/now/table/sys_remote_update_set/{{REMOTE_SYS_ID}}?sysparm_fields=sys_id,name,state",
              "protocol": "https",
              "host": ["{{SN_TEST_INSTANCE}}", "service-now", "com"],
              "path": ["api", "now", "table", "sys_remote_update_set", "{{REMOTE_SYS_ID}}"],
              "query": [
                { "key": "sysparm_fields", "value": "sys_id,name,state" }
              ]
            },
            "description": "Confirms the remote update set reached `committed` state.\n\n**Expected:** `result.state === 'committed'`"
          },
          "response": []
        }
      ]
    }
